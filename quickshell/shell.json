{
    "appearance": {
        "accentColor": "auto",
        "fontFamily": "Noto Sans",
        "fontScale": 1,
        "radius": 16,
        "shadows": true,
        "theme": "dark"
    },
    "bluetooth": {
        "showName": true
    },
    "clock": {
        "bold": false,
        "fontSize": 9,
        "horizontalFormat": "hh:mm",
        "verticalFormat": "hh\nmm"
    },
    "frames": {
        "enabled": false,
        "radius": 16,
        "width": 4
    },
    "network": {
        "showName": false
    },
    "notifications": {
        "compact": false,
        "displayTime": 4500,
        "position": [
            "top",
            ""
        ]
    },
    "panel": {
        "position": "top",
        "size": 42
    },
    "pipewire": {
        "audio": {
            "showPercentage": true
        },
        "mic": {
            "showPercentage": false
        }
    },
    "systemTray": {
        "appBlackList": [
        ],
        "items": {
            "onDemand": [
                "mic",
                "bluetooth"
            ],
            "pinned": [
                "audio",
                "upower",
                "network"
            ]
        }
    },
    "upower": {
        "low_threshold": 25,
        "showPercentage": true,
        "verylow_threshold": 15
    },
    "wallpapers": {
        "folder": "~/.config/wallpapers",
        "transitionDuration": 1,
        "transitionFps": 60,
        "transitionStep": 90,
        "transitionType": "random"
    },
    "workspaces": {
        "iconSize": 16,
        "iconSpacing": 6,
        "radius": 99,
        "workspaceSpacing": 8
    }
}
