{
    "clock": {
        "bold": true,
        "fontSize": 10,
        "horizontalFormat": "hh:mm",
        "verticalFormat": "hh\nmm"
    },
    "color": "auto",
    "fontFamily": "Adwaita Sans",
    "fontScale": 1,
    "frames": {
        "enabled": true,
        "radius": 8,
        "width": 4
    },
    "notifications": {
        "compact": false,
        "displayTime": 4500,
        "position": [
            "top",
            "right"
        ]
    },
    "panel": {
        "position": "left",
        "size": 44
    },
    "systemTray": {
        "iconSize": 16,
        "padding": 5,
        "spacing": 8
    },
    "theme": "dark",
    "wallpapers": {
        "fallbackColor": "#e9cbcb",
        "folder": "~/.config/wallpapers"
    },
    "workspaces": {
        "iconSize": 16,
        "iconSpacing": 0,
        "radius": 16,
        "workspaceSpacing": 4
    }
}
