{
    "appearance": {
        "accentColor": "auto",
        "fontFamily": "Adwaita Sans",
        "fontScale": 1,
        "preferredMonitorWallpaperIndex": 0,
        "radius": 8,
        "shadows": true,
        "theme": "dark"
    },
    "clock": {
        "bold": false,
        "fontSize": 9,
        "horizontalFormat": "hh:mm",
        "icon": true,
        "verticalFormat": "hh\nmm"
    },
    "notifications": {
        "displayTime": -1,
        "position": "top:right",
        "showCount": false
    },
    "panel": {
        "backgroundOpacity": 1,
        "margins": 0,
        "moduleSpacing": 4,
        "modules": {
            "center": [
            ],
            "end": [
                "status_tray",
                "separator",
                "notifications",
                "clock"
            ],
            "start": [
                "workspaces",
                "separator"
            ]
        },
        "position": "top",
        "radius": 0,
        "size": 40
    },
    "systemTray": {
        "columnSpacing": 0,
        "fontSize": 7.6,
        "items": [
            {
                "active": true,
                "name": "mic",
                "reactive": true,
                "showPercentage": false
            },
            {
                "active": true,
                "name": "battery",
                "reactive": false,
                "showPercentage": false
            },
            {
                "active": true,
                "name": "sound",
                "showPercentage": false
            }
        ],
        "moduleSpacing": 4,
        "rowSpacing": 4
    },
    "upower": {
        "low_threshold": 25,
        "verylow_threshold": 15
    },
    "wallpapers": {
        "folder": "~/.config/wallpapers",
        "transitionDuration": 1,
        "transitionFps": 60,
        "transitionStep": 90,
        "transitionType": "random"
    },
    "workspaces": {
        "iconSize": 25,
        "iconSpacing": 4,
        "radius": 25,
        "workspaceSpacing": 6
    }
}
