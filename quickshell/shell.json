{
    "appearance": {
        "accentColor": "#ed8796",
        "fontFamily": "Adwaita Sans",
        "fontScale": 1,
        "radius": 8,
        "shadows": true,
        "theme": "dark"
    },
    "bluetooth": {
        "showName": false
    },
    "clock": {
        "bold": false,
        "fontSize": 9,
        "horizontalFormat": "hh:mm",
        "verticalFormat": "hh mm"
    },
    "frames": {
        "enabled": false,
        "radius": 16,
        "width": 4
    },
    "network": {
        "showName": false
    },
    "notifications": {
        "compact": false,
        "displayTime": 4500,
        "position": [
            "",
            ""
        ]
    },
    "panel": {
        "position": "left",
        "size": 45
    },
    "pipewire": {
        "audio": {
            "showPercentage": false
        },
        "mic": {
            "showPercentage": false
        }
    },
    "systemTray": {
        "appBlackList": [],
        "items": {
            "onDemand": [],
            "pinned": [
                "bluetooth",
                "mic",
                "audio",
                "upower",
                "network"
            ]
        }
    },
    "upower": {
        "low_threshold": 25,
        "showPercentage": true,
        "verylow_threshold": 15
    },
    "wallpapers": {
        "fallbackColor": "000000",
        "folder": "~/.config/wallpapers"
    },
    "workspaces": {
        "iconSize": 16,
        "iconSpacing": 6,
        "radius": 99,
        "workspaceSpacing": 8
    }
}
